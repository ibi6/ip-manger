# development | production
APP_ENV=development

# 生产环境必须设置（≥32 字符随机串）。开发环境可留空，将自动生成 backend/.secret_key
SECRET_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:///./ipam.db

# 逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://127.0.0.1:5173,http://localhost,http://127.0.0.1

# 登录限流：窗口秒数内最大尝试次数
# LOGIN_RATE_LIMIT=8
# LOGIN_RATE_WINDOW_SECONDS=60

# 仅当 API 只通过受控反向代理访问时设为 true，届时才信任 X-Forwarded-For
TRUST_PROXY_HEADERS=false

# 开发环境默认加载演示数据；设为 false 可测试空库初始化
# 生产环境始终禁止演示数据
SEED_DEMO_DATA=true

# 空生产数据库的首次管理员。首次成功启动后应从部署环境移除密码变量。
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=NetLedger 管理员
BOOTSTRAP_ADMIN_PASSWORD=
