# Copy to .env for Docker Compose. Never commit the real .env file.
APP_ENV=development
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:////data/ipam.db
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Development demo mode. Production must set false.
SEED_DEMO_DATA=true

# Required only for the first start of an empty non-demo database.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=NetLedger 管理员
BOOTSTRAP_ADMIN_PASSWORD=
